@article{CONG2026100203,
  author = {Cong, Yan and Hu, Jingying and Reese, Timothy and Liu, Hui},
  title = {How robust are linguistic markers of aging? {T}he case of aging-related social media text},
  journal = {Natural Language Processing Journal},
  volume = {14},
  pages = {100203},
  year = {2026},
  issn = {2949-7191},
  doi = {10.1016/j.nlp.2026.100203},
  html = {https://www.sciencedirect.com/science/article/pii/S2949719126000075},
  abstract = {Recent research suggests that linguistic biomarkers are effective in detecting probable cognitive impairment (PCI). This study extends this line of research by examining whether linguistic markers, which have been previously validated in structured, controlled clinical settings, are sufficiently robust to effectively detect PCI in unstructured, spontaneous, everyday social media posts. ML classifiers, especially gradient boosting, achieved high precision, recall, and overall accuracy in distinguishing PCI from HC across both data types. Classic linguistic markers remained the most influential predictors. These findings demonstrated a reliable approach to transfer linguistic markers from clinical, controlled settings to spontaneous, unstructured social media posts.},
  bibtex_show = {true},
  selected = {true},
}


